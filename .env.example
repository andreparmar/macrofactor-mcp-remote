# MacroFactor Firebase credentials
# Run: npm run get-refresh-token  (needs MACROFACTOR_USERNAME + MACROFACTOR_PASSWORD locally)
# Then paste the output here / into Railway env vars — password stays local
FIREBASE_REFRESH_TOKEN=

# Firebase + Typesense keys (extract from MacroFactor app traffic or use known values)
FIREBASE_WEB_API_KEY=
TYPESENSE_HOST=
TYPESENSE_API_KEY=

# OAuth admin password — set something strong, this protects the MCP endpoint
OAUTH_ADMIN_PASSWORD=

# Public URL of this server (required for OAuth discovery to return correct URLs)
# On Railway this is typically: https://<service-name>.railway.app
BASE_URL=

# HTTP port (Railway sets this automatically)
PORT=3001
